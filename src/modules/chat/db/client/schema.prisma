datasource db {
  provider = "postgresql"
  url      = env("CHAT_DATABASE_URL")
  schemas  = ["chat"]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  output          = "../client"
}

model UserDevice {
  id              String   @id @default(uuid())
  userId          String
  deviceId        String   @unique
  deviceName      String
  devicePublicKey String
  isActive        Boolean  @default(true)
  lastSeenAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([userId])
  @@schema("chat")
}

model Conversation {
  id        String   @id @default(uuid())
  type      String   @default("direct") // direct, group
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("chat")
}

model Participant {
  conversationId String
  userId         String
  role           String   @default("member")
  joinedAt       DateTime @default(now())

  @@id([conversationId, userId])
  @@schema("chat")
}

// Stores the Symmetric Conversation Key encrypted for each specific device
model ConversationKey {
  id             String   @id @default(uuid())
  conversationId String
  deviceId       String
  encryptedKey   String // AES Conversation Key encrypted with devicePublicKey
  addedAt        DateTime @default(now())

  @@unique([conversationId, deviceId])
  @@schema("chat")
}

model Message {
  id             String @id @default(uuid())
  conversationId String
  senderId       String

  // Encrypted Payload for E2EE
  ciphertext String?
  nonce      String?
  authTag    String?

  // Legacy plaintext content (for migration)
  content String?

  // Image sharing support
  imageUrl String?

  // We keep read flag for simple read receipts compatibility
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
  @@schema("chat")
}

model MessageReceipt {
  messageId String
  userId    String
  deviceId  String
  status    String // "delivered", "read"
  timestamp DateTime @default(now())

  @@id([messageId, userId, deviceId])
  @@schema("chat")
}
