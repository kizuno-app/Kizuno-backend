datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["discover"]
}

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  output   = "../client"
}

model DiscoverTopic {
  id        String   @id @default(uuid())
  name      String   @unique
  score     Float    @default(0)
  updatedAt DateTime @updatedAt

  @@schema("discover")
}
