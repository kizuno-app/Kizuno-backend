datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["report"]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  output          = "../client"
  binaryTargets   = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

model Report {
  id              String   @id @default(uuid())
  reporterId      String
  targetType      String   // "POST" or "USER"
  targetId        String
  category        String   // "Spam", "Harassment", "Fake Identity", "Misinformation", "NSFW", "Other"
  reason          String?
  status          String   @default("PENDING") // "PENDING", "RESOLVED"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@schema("report")
}

model ModerationCase {
  id              String   @id @default(uuid())
  targetType      String   // "POST" or "USER"
  targetId        String   @unique
  reportCount     Int      @default(0)
  status          String   @default("OPEN") // "OPEN", "ACTIONED", "DISMISSED"
  actionTaken     String?  // "WARN", "SUSPEND", "DELETE", "DISMISS"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@schema("report")
}
