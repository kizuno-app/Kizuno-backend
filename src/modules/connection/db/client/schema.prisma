datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["connection"]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  output          = "../client"
}

model Connection {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  @@id([followerId, followingId])
  @@schema("connection")
}
