datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["connection"]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  output          = "../client"
  binaryTargets   = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

model Connection {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  @@id([followerId, followingId])

  @@schema("connection")
}
