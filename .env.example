PORT=5000
NODE_ENV=production
HOST=0.0.0.0

# Neon DB Postgres URL
DATABASE_URL="postgresql://user:password@ep-something.us-east-2.aws.neon.tech/neondb?sslmode=require&connect_timeout=30&connection_limit=2"
CHAT_DATABASE_URL="postgresql://user:password@ep-something.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&connect_timeout=30&connection_limit=2"

# Upstash Redis
UPSTASH_REDIS_REST_URL="rediss://default:password@us1-something.upstash.io:6379"

JWT_SECRET="generate-a-strong-secret-here"
JWT_EXPIRES_IN="1d"

# Frontend URL (the URL your frontend is accessible at)
CLIENT_URL="http://your-frontend-ip-or-domain:3000"

# Optional: Comma-separated list of allowed CORS origins
# ALLOWED_ORIGINS="http://your-frontend-ip:3000,https://yourdomain.com"

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Chat Cloudinary (if separate from main)
CHAT_CLOUDINARY_CLOUD_NAME=""
CHAT_CLOUDINARY_API_SECRET=""

# Email (Resend)
RESEND_API_KEY=""
MAIL_FROM_AUTH="Kizuno Auth <noreply@auth.yourdomain.com>"
MAIL_FROM_ORG="Kizuno Organizations <organizations@yourdomain.com>"
MAIL_FROM_SECURITY="Kizuno Security <security@yourdomain.com>"
MAIL_FROM_GENERAL="Kizuno <hello@yourdomain.com>"
MAIL_REPLY_TO="support@yourdomain.com"
