PORT=3000
NODE_ENV=development

# Neon DB Postgres URL
DATABASE_URL="postgresql://user:password@ep-something.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Upstash Redis
UPSTASH_REDIS_REST_URL="rediss://default:password@us1-something.upstash.io:30000"

JWT_SECRET="super-secret-key"
JWT_EXPIRES_IN="1d"
CLIENT_URL="http://localhost:3000"

# Email (Resend)
RESEND_API_KEY=""
MAIL_FROM_AUTH="Kizuna Auth <noreply@auth.yourdomain.com>"
MAIL_FROM_ORG="Kizuna Org <onboarding@org.yourdomain.com>"
MAIL_FROM_SECURITY="Kizuna Security <security@auth.yourdomain.com>"
MAIL_FROM_GENERAL="Kizuna <hello@yourdomain.com>"
MAIL_REPLY_TO="support@yourdomain.com"

